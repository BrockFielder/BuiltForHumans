@model List<Project>

@{
    ViewData["Title"] = "Projects";
}

<h1 class="mb-4">Projects</h1>

@if (!Model.Any())
{
    <p class="text-muted">No projects yet.</p>
}
else
{
    <div class="row">
        @foreach (var project in Model)
        {
            var cover = project.Images.FirstOrDefault();

            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (cover is not null)
                    {
                        <img src="@cover.FilePath" class="card-img-top" alt="@cover.Caption"
                             style="height: 220px; object-fit: cover;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@project.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">
                            @project.Location · @project.ProjectType · @project.StartDate.Year
                        </h6>
                        <p class="card-text">@project._description</p>
                        <a asp-controller="Project"
                           asp-action="GetProject"
                           asp-route-id="@project.Id"
                           class="mt-auto">
                            View project →
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}